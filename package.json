{
  "name": "blog-assignment",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev --workspace=api\" \"npm run dev --workspace=web\"",
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run start:dev --workspace=api",
    "db:migrate": "npm run db:migrate --workspace=api",
    "db:push": "npm run db:push --workspace=api",
    "db:seed": "npm run db:seed --workspace=api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
